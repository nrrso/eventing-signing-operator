{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "matchManagers": ["maven"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "matchManagers": ["maven"],
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "matchManagers": ["mise"],
      "automerge": false
    },
    {
      "groupName": "quarkus",
      "matchManagers": ["maven"],
      "matchPackageNames": [
        "io.quarkus{/,}**"
      ]
    },
    {
      "groupName": "cloudevents",
      "matchManagers": ["maven"],
      "matchPackageNames": [
        "io.cloudevents{/,}**"
      ]
    },
    {
      "groupName": "operator-sdk",
      "matchManagers": ["maven"],
      "matchPackageNames": [
        "io.javaoperatorsdk{/,}**",
        "io.quarkiverse.operatorsdk{/,}**"
      ]
    }
  ]
}
